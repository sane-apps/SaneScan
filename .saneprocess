# SaneProcess compliance manifest
name: SaneScan
type: ios_app
scheme: SaneScan
project: SaneScan.xcodeproj
bundle_id: com.sanescan.app

build:
  xcodegen: true

tests:
  unit_dir: Tests
  unit_target: SaneScanTests
  unit_scheme: SaneScan
  unit_destination: "platform=iOS Simulator,name=iPhone 17 Pro"

commands:
  verify: ./scripts/SaneMaster.rb verify
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean

docs:
  - AGENTS.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6770391054"
  product_id: "com.sanescan.app.pro.annual"
  scheme: SaneScan
  configuration: Release-AppStore
  platforms: [ios]
  ios_scheme: SaneScan
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://sanescan-site.pages.dev/privacy"
  support_url: "https://saneapps.com"
  marketing_url: "https://sanescan-site.pages.dev"
  metadata:
    ios:
      subtitle: "Private Document Scanner"
      promotional_text: "Scan documents, receipts, forms, and old photos privately with local OCR and PDF export."
      description: >-
        SaneScan is a private scanner for documents, receipts, forms, and old photos.
        Scan pages with Apple's system document scanner, import archive photos,
        clean up images locally, recognize text on device, and export PDFs.
        SaneScan does not require an account and does not upload scan contents
        to SaneApps servers.
      keywords: "scanner,document,receipt,ocr,pdf,form,private,archive,photo scan"
      whats_new: "Initial release."
      marketing_url: "https://sanescan-site.pages.dev"
  review_notes: "SaneScan is a freemium iOS document scanner. Basic includes 10 scans per month. SaneScan Pro is sold through StoreKit only and unlocks unlimited scans, batch import, OCR sidecars, and PDF export. No account, external checkout, license key, or server upload is used. Camera permission is requested only when starting a scan; Photos permission is requested only when importing selected photos; export uses the system share sheet."
  iap:
    product_id: "com.sanescan.app.pro.annual"
    display_name: "SaneScan Pro Yearly"
    type: auto_renewable_subscription
    price_usd: 29.99
    description: "Unlimited private scanning, batch import, OCR, and PDF export."
    review_note: "SaneScan Pro Yearly is an auto-renewable StoreKit subscription for unlimited private scanning, batch import, OCR sidecars, and PDF export. No external checkout links or license keys are used."
  planned_iap:
    - product_id: "com.sanescan.app.pro.lifetime"
      display_name: "SaneScan Pro Lifetime"
      type: non_consumable
      price_usd: 49.99
      description: "Lifetime unlock for unlimited private scanning, batch import, OCR, and PDF export."
  screenshots:
    ios: docs/images/screenshot-ios-*-dark.png
    ipad: docs/images/screenshot-ipad-*-dark.png
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: sanescan.com
